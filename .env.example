# ── RootLensAI Backend — Environment Configuration ────────────────────────────

# MongoDB connection URI
MONGODB_URI=mongodb://localhost:27017

# MongoDB database name
DATABASE_NAME=rootlensai

# Groq API key (required for AI analysis)
# Get yours at: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Allowed CORS origins (comma-separated or JSON array)
# Development:
ALLOWED_ORIGINS=["http://localhost:3000"]
# Production:
# ALLOWED_ORIGINS=["https://your-frontend.vercel.app"]

# Upload directory (relative to project root)
UPLOAD_DIR=uploads

# Maximum file size in MB
MAX_FILE_SIZE_MB=50

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Enable mock telemetry streaming via WebSocket
ENABLE_MOCK_TELEMETRY=true
